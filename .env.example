# Public URL used in email links after deployment.
# Local default is derived from the request host, for example http://localhost:4173.
PUBLIC_BASE_URL=https://example.com

# Leave SMTP_HOST empty in local development to write emails to data/outbox.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM="Notes <your-smtp-user@example.com>"

# Optional server settings.
PORT=4173
