{
  "name": "zhihu-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env src/server.js",
    "dev": "node --env-file=.env --watch src/server.js",
    "import:zhihu": "node scripts/import-zhihu-export.mjs",
    "collect:zhihu": "node scripts/collect-zhihu.mjs",
    "login:zhihu": "node scripts/collect-zhihu.mjs --login --channel chrome",
    "login:zhihu:server": "node scripts/zhihu-server-login.mjs",
    "sync:zhihu": "node scripts/collect-zhihu.mjs --sync --import --headless --noLoginWait",
    "sync:zhihu:comments": "node scripts/sync-zhihu-comments.mjs",
    "sync:keep:trades": "node scripts/sync-keep-trades.mjs --import",
    "repair:zhihu": "node scripts/repair-zhihu-db.mjs",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
